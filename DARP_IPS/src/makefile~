TARGET = exe

EXT = cpp
CXX = g++
CXXFLAGS = -g -DIL_STD -DNDEBUG -std=c++11

CPLEXPATH = /home/ibm/cplex-studio/22.1/

CPLEXDIR      = $(CPLEXPATH)/cplex
CONCERTDIR    = $(CPLEXPATH)/concert

CONCERTINCDIR = $(CONCERTDIR)/include/
CPLEXINCDIR   = $(CPLEXDIR)/include/

CONCERTLIBDIR = $(CONCERTDIR)/lib/x86-64_linux/static_pic
CPLEXLIBDIR   = $(CPLEXDIR)/lib/x86-64_linux/static_pic

OUTDIR = .
SUBDIR = data utilities solvers
#DIR_OBJ = ./obj
DIR_OBJ = .

INCS = $(wildcard *.h $(foreach fd, $(SUBDIR), $(fd)/*.h))
SRCS = $(wildcard *.c $(foreach fd, $(SUBDIR), $(fd)/*.$(EXT)))
NODIR_SRC = $(notdir $(SRCS))
OBJS = $(addprefix $(DIR_OBJ)/, $(SRCS:$(EXT)=o)) # obj/xxx.o obj/folder/xxx .o
INC_DIRS = -I./ $(addprefix -I, $(SUBDIR)) -I$(CPLEXINCDIR) -I$(CONCERTINCDIR)
LIBS = -lilocplex -lcplex -lconcert -lm -lpthread -ldl
LIB_DIRS = -L. -L$(CPLEXLIBDIR) -L$(CONCERTLIBDIR)

PHONY := $(TARGET)
$(TARGET): $(OBJS)
	$(CXX) -o $(OUTDIR)/$@ $(OBJS) $(LIB_DIRS) $(LIBS)

$(DIR_OBJ)/%.o: %.$(EXT) $(INCS)
#	mkdir -p $(@D)
	$(CXX) -o $@ $(CFLAGS) -c $< $(INC_DIRS)

PHONY += clean
clean:
	rm -rf $(OUTDIR)/$(TARGET) $(OBJS)

PHONY += echoes
echoes:
    @echo "INC files: $(INCS)"
    @echo "SRC files: $(SRCS)"
    @echo "OBJ files: $(OBJS)"
    @echo "LIB files: $(LIBS)"
    @echo "INC DIR: $(INC_DIRS)"
    @echo "LIB DIR: $(LIB_DIRS)"

.PHONY = $(PHONY)
