#!/bin/bash


# Define the base folder names
base_folders=("20150706_07-120m" "20150715_07-120m" "20150804_07-120m" "20150828_07-120m" "20150917_07-120m" "20150926_07-120m" "20151008_07-120m" "20151025_07-120m" "20151110_07-120m" "20151130_07-120m" "20151211_07-120m" "20151230_07-120m" "20160109_07-120m" "20160129_07-120m" "20160222_07-120m" "20160225_07-120m" "20160316_07-120m" "20160329_07-120m" "20160401_07-120m" "20160427_07-120m" "20160512_07-120m" "20160521_07-120m" "20160613_07-120m" "20160628_07-120m")

# Loop through each base folder name
for base in "${base_folders[@]}"; do
    # Create subfolders from 1 to 31
    for i in $(seq 1 31); do
        mkdir -p "${base}_${i}"
    done
done

echo "Folders created successfully."
